# Local environment variables. Copy to .env and fill values locally.

AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=
AZURE_LOCATION=eastus
AZURE_RESOURCE_GROUP=
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_POSTGRES_DSN=
AZURE_KEY_VAULT_URL=
AZURE_FUNCTION_APP=
OPENAI_API_KEY=
GITHUB_TOKEN=
DATALOAD_INITIAL_LOOKBACK_DAYS=180
REDDIT_DATALOAD_SCHEDULE=0 0 * * * *
HACKER_NEWS_DATALOAD_SCHEDULE=0 10 * * * *
GITHUB_DATALOAD_SCHEDULE=0 20 * * * *

PROCESSING_PREPARE_SCHEDULE=0 30 1 * * *
PROCESSING_SYNTHESIS_SCHEDULE=0 30 2 * * *
PROCESSING_RELEVANCE_THRESHOLD=0
PROCESSING_SIMILARITY_THRESHOLD=0.0
PROCESSING_CONNECTION_CONFIDENCE_THRESHOLD=0.25
PROCESSING_MAX_AGENT_SEARCHES=5
PROCESSING_TEMPORAL_WINDOW_DAYS=180
PROCESSING_MAX_CONNECTION_CANDIDATES_PER_TICKER=5
OPENAI_ENRICHMENT_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
